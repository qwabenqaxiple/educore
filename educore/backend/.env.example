# EduCore SMS — Backend Environment Variables
# Copy to .env and fill in your values

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Option A: Full connection string (Render, Railway, Supabase, etc.)
DATABASE_URL=postgresql://postgres:xiple@23@localhost:5432/educore

# Option B: Individual fields (use one or the other)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=educore
# DB_USER=postgres
# DB_PASSWORD=password

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production
JWT_EXPIRES_IN=7d

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# For Gmail: enable "App Passwords" in Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-school-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=EduCore SMS <noreply@educore.edu>

# ─── SMS (Twilio — optional) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1234567890

# ─── CORS ────────────────────────────────────────────────────────────────────
# Frontend URL (for production)
FRONTEND_URL=http://localhost:3000

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880   # 5MB in bytes
